{
  "manifest_version": 3,
  "name": "FB小组检测器",
  "version": "1.6.0",
  "description": "FB小组检测器：解析群聊链接，检测复制组与通话意外挂断并提醒",
  "permissions": ["activeTab", "scripting", "clipboardWrite", "tabs", "notifications", "storage", "downloads"],
  "host_permissions": [
    "https://www.facebook.com/*",
    "https://facebook.com/*",
    "https://www.messenger.com/*",
    "https://messenger.com/*",
    "https://m.me/*",
    "https://api.github.com/*",
    "https://github.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "FB小组检测器"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.facebook.com/*",
        "https://facebook.com/*",
        "https://www.messenger.com/*",
        "https://messenger.com/*"
      ],
      "js": ["extractor.js", "ui-shared.js", "content.js", "call-monitor.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
